// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
}

model Vendor {
  id              Int                   @id @default(autoincrement())
  company_name    String
  gst_number      String                @unique
  category        String
  status          String
  contact_name    String?
  contact_email   String?
  contact_phone   String?
  created_at      DateTime              @default(now())
  updated_at      DateTime              @updatedAt
  rfq_assignments RFQVendorAssignment[]
  quotations      Quotation[]
}

model RFQ {
  id               Int                   @id @default(autoincrement())
  title            String
  category         String
  deadline         DateTime
  description      String
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt
  line_items       RFQLineItem[]
  assigned_vendors RFQVendorAssignment[]
  attachments      RFQAttachment[]
  quotations       Quotation[]
}

model Quotation {
  id            Int      @id @default(autoincrement())
  rfq           RFQ      @relation(fields: [rfq_id], references: [id])
  rfq_id        Int
  vendor        Vendor   @relation(fields: [vendor_id], references: [id])
  vendor_id     Int
  total_amount  Float
  delivery_days Int
  status        String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model RFQLineItem {
  id         Int      @id @default(autoincrement())
  rfq        RFQ      @relation(fields: [rfq_id], references: [id])
  rfq_id     Int
  item       String
  quantity   Int
  unit       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model RFQVendorAssignment {
  id         Int      @id @default(autoincrement())
  rfq        RFQ      @relation(fields: [rfq_id], references: [id])
  rfq_id     Int
  vendor     Vendor   @relation(fields: [vendor_id], references: [id])
  vendor_id  Int
  assigned_at DateTime @default(now())
}

model RFQAttachment {
  id         Int      @id @default(autoincrement())
  rfq        RFQ      @relation(fields: [rfq_id], references: [id])
  rfq_id     Int
  file_name  String
  file_url   String
  file_type  String?
  file_size  Int?
  uploaded_at DateTime @default(now())
}
